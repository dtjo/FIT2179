{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2a2a2a",
      "domainColor": "#2a2a2a",
      "tickColor": "#2a2a2a",
      "labelColor": "#888",
      "titleColor": "#888",
      "labelFontSize": 12
    },
    "view": { "stroke": "transparent" },
    "legend": { "labelColor": "#888", "titleColor": "#888", "orient": "top-left" }
  },
  "data": { "url": "Data/coffee_cpi.csv" },
  "transform": [
    { "fold": ["CPI Growth", "Coffee Price Growth"], "as": ["Measure", "Value"] }
  ],
  "mark": { "type": "bar", "cornerRadiusTopLeft": 2, "cornerRadiusTopRight": 2, "width": { "band": 0.4 } },
  "encoding": {
    "x": { "field": "Year", "type": "ordinal", "axis": { "labelAngle": -45 } },
    "y": { "field": "Value", "type": "quantitative", "axis": { "title": "Growth (%)", "format": ".1f" } },
    "color": {
      "field": "Measure",
      "scale": { "domain": ["CPI Growth", "Coffee Price Growth"], "range": ["#e8c547", "#e05c3a"] }
    },
    "xOffset": { "field": "Measure" },
    "tooltip": [
      { "field": "Year", "title": "Year" },
      { "field": "Measure" },
      { "field": "Value", "format": ".2f" }
    ]
  }
}
