{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 340,
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2a2a2a",
      "domainColor": "#2a2a2a",
      "tickColor": "#2a2a2a",
      "labelColor": "#888",
      "titleColor": "#888",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "view": { "stroke": "transparent" },
    "legend": {
      "labelColor": "#888",
      "titleColor": "#888",
      "orient": "top-left",
      "padding": 8
    }
  },
  "data": {
    "values": [
      {"Year": 2015, "WPI": 2.2, "Inflation": 1.51},
      {"Year": 2016, "WPI": 1.9, "Inflation": 1.28},
      {"Year": 2017, "WPI": 2.1, "Inflation": 1.95},
      {"Year": 2018, "WPI": 2.3, "Inflation": 1.91},
      {"Year": 2019, "WPI": 2.2, "Inflation": 1.61},
      {"Year": 2020, "WPI": 1.3, "Inflation": 0.85},
      {"Year": 2021, "WPI": 2.4, "Inflation": 2.86},
      {"Year": 2022, "WPI": 3.3, "Inflation": 6.59},
      {"Year": 2023, "WPI": 4.3, "Inflation": 5.60},
      {"Year": 2024, "WPI": 3.2, "Inflation": 3.17},
      {"Year": 2025, "WPI": 3.4, "Inflation": 3.80}
    ]
  },
  "layer": [
    {
      "mark": { "type": "rect", "opacity": 0.06, "color": "#e05c3a" },
      "data": { "values": [{ "x1": 2021.5, "x2": 2023.5 }] },
      "encoding": {
        "x": { "field": "x1", "type": "quantitative" },
        "x2": { "field": "x2" }
      }
    },
    {
      "transform": [
        { "fold": ["WPI", "Inflation"], "as": ["Measure", "Value"] }
      ],
      "mark": { "type": "line", "strokeWidth": 2.5, "point": { "filled": true, "size": 50 } },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative", "axis": { "format": "d", "tickCount": 11 } },
        "y": { "field": "Value", "type": "quantitative", "axis": { "title": "Rate (%)", "format": ".1f" } },
        "color": {
          "field": "Measure",
          "scale": { "domain": ["WPI", "Inflation"], "range": ["#4caf7d", "#e05c3a"] }
        },
        "tooltip": [
          { "field": "Year", "title": "Year", "format": "d" },
          { "field": "Measure", "title": "Metric" },
          { "field": "Value", "title": "Rate (%)", "format": ".2f" }
        ]
      }
    },
    {
      "data": { "values": [{ "Year": 2022, "Value": 6.59, "label": "⚠ Cost-of-living crisis" }] },
      "mark": { "type": "text", "align": "left", "dx": 8, "dy": -10, "fontSize": 11, "color": "#e05c3a", "fontStyle": "italic" },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative" },
        "y": { "field": "Value", "type": "quantitative" },
        "text": { "field": "label" }
      }
    }
  ]
}
