{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2a2a2a",
      "domainColor": "#2a2a2a",
      "tickColor": "#2a2a2a",
      "labelColor": "#888",
      "titleColor": "#888",
      "labelFontSize": 12
    },
    "view": { "stroke": "transparent" },
    "legend": { "labelColor": "#888", "titleColor": "#888", "orient": "top-left" }
  },
  "data": { "url": "Data/gold.csv" },
  "transform": [
    { "fold": ["Gold Price", "Cash "], "as": ["Asset", "Value"] }
  ],
  "mark": { "type": "area", "opacity": 0.15, "line": { "strokeWidth": 2.5 } },
  "encoding": {
    "x": { "field": "Year", "type": "ordinal", "axis": { "labelAngle": -45 } },
    "y": { "field": "Value", "type": "quantitative", "axis": { "title": "Indexed (2015 = 100)" }, "scale": { "zero": false } },
    "color": {
      "field": "Asset",
      "scale": { "domain": ["Gold Price", "Cash "], "range": ["#e8c547", "#888"] }
    },
    "tooltip": [
      { "field": "Year", "title": "Year" },
      { "field": "Asset" },
      { "field": "Value", "format": ".1f" }
    ]
  }
}
