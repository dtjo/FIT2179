{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 400,

  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/Data/CPI.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(datum.Year)",
      "as": "YearNum"
    },
    {
      "calculate": "toNumber(datum.CPI)",
      "as": "CPINum"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {
    "x": {
      "field": "YearNum",
      "type": "quantitative",
      "title": "Year"
    },
    "y": {
      "field": "CPINum",
      "type": "quantitative",
      "title": "CPI"
    }
  }
}