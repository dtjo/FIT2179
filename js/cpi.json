{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2a2a2a",
      "domainColor": "#2a2a2a",
      "tickColor": "#2a2a2a",
      "labelColor": "#888",
      "titleColor": "#888",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "view": { "stroke": "transparent" }
  },
  "data": {
    "url": "Data/cpi.csv"
  },
  "transform": [{ "sort": [{"field": "Year", "order": "ascending"}] }],
  "layer": [
    {
      "mark": { "type": "area", "line": true, "color": "#e8c547", "fillOpacity": 0.08, "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "Year", "type": "ordinal", "axis": { "labelAngle": -45 }, "sort": "ascending" },
        "y": { "field": "CPI", "type": "quantitative", "axis": { "title": "CPI Index" }, "scale": { "zero": false } },
        "color": { "value": "#e8c547" }
      }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 60 },
      "encoding": {
        "x": { "field": "Year", "type": "ordinal", "sort": "ascending" },
        "y": { "field": "CPI", "type": "quantitative", "scale": { "zero": false } },
        "color": { "value": "#e8c547" },
        "tooltip": [
          { "field": "Year", "title": "Year" },
          { "field": "CPI", "title": "CPI Index", "format": ".2f" }
        ]
      }
    }
  ]
}
