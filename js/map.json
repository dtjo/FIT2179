{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [132, -28],
    "scale": 700
    },
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/js/australia_states.json",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": {"url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/Data/state_cpi.csv"},
        "key": "state",
        "fields": ["CPI"]
      }
    }
  ],
  "mark": "geoshape",
  "encoding": {
    "color": {
      "field": "CPI",
      "type": "quantitative",
      "scale": {"scheme": "blues"}
    },
    "tooltip": [
      {"field": "properties.STE_NAME16", "title": "State"},
      {"field": "CPI"}
    ]
  }
}