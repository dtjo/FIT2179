{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 600,
  "height": 500,

  "projection": {"type": "equalEarth"},

  "data": {
    "url": "js/australia_states.topojson",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },

  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": {
          "url": "Data/state_cpi.csv"
        },
        "key": "state",
        "fields": ["CPI"]
      }
    }
  ],

  "mark": "geoshape",

  "encoding": {
    "color": {
      "field": "CPI",
      "type": "quantitative",
      "scale": {"scheme": "blues"}
    },
    "tooltip": [
      {"field": "properties.STE_NAME", "title": "State"},
      {"field": "CPI"}
    ]
  }
}