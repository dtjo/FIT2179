{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "legend": { "labelColor": "#888", "titleColor": "#888" },
    "view": { "stroke": "transparent" }
  },
  "projection": { "type": "mercator", "center": [132, -28], "scale": 650 },
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/js/australia_states.json",
    "format": { "type": "topojson", "feature": "STE_2016_AUST" }
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": { "url": "Data/state_cpi.csv" },
        "key": "state",
        "fields": ["CPI"]
      }
    }
  ],
  "mark": { "type": "geoshape", "stroke": "#0d0d0d", "strokeWidth": 1.5 },
  "encoding": {
    "color": {
      "field": "CPI",
      "type": "quantitative",
      "scale": { "scheme": "orangered", "domain": [4.0, 5.2] },
      "legend": { "title": "CPI (%)" }
    },
    "tooltip": [
      { "field": "properties.STE_NAME16", "title": "State" },
      { "field": "CPI", "title": "CPI (%)", "format": ".1f" }
    ]
  }
}
