{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 420,
  "title": "Australia States Map",
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "data/australia_states.json",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },
  "mark": {
    "type": "geoshape",
    "fill": "#E6E6E6",
    "stroke": "white",
    "strokeWidth": 1
  }
}