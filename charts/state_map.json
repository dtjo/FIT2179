{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 700,
  "height": 420,
  "projection": {
    "type": "mercator",
    "center": [132, -28],
    "scale": 650
  },
  "data": {
    "url": "data/australia_states.json",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": {
          "url": "data/state_cpi.csv"
        },
        "key": "state",
        "fields": ["CPI"]
      }
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "#0d0d0d",
    "strokeWidth": 1.4
  },
  "encoding": {
    "color": {
      "field": "CPI",
      "type": "quantitative",
      "scale": {
        "scheme": "orangered"
      },
      "legend": {
        "title": "CPI (%)"
      }
    },
    "tooltip": [
      {
        "field": "properties.STE_NAME16",
        "title": "State"
      },
      {
        "field": "CPI",
        "title": "CPI (%)",
        "format": ".1f"
      }
    ]
  }
}