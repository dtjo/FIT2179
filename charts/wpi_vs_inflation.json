{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#d6cfbf",
      "titleColor": "#d6cfbf",
      "orient": "top"
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "width": "container",
  "height": 330,
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main//data/wpi_inflation.csv"
  },
  "transform": [
    {
      "fold": [
        "WPI",
        "Inflation Rate (%)"
      ],
      "as": [
        "Measure",
        "Value"
      ]
    }
  ],
  "layer": [
    {
      "data": {
        "values": [
          {
            "start": 2021.5,
            "end": 2023.5
          }
        ]
      },
      "mark": {
        "type": "rect",
        "color": "#e05c3a",
        "opacity": 0.08
      },
      "encoding": {
        "x": {
          "field": "start",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": null
        },
        "x2": {
          "field": "end"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "size": 55
        }
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "format": "d",
            "tickCount": 11,
            "title": "Year",
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Value",
          "type": "quantitative",
          "axis": {
            "title": "Rate (%)"
          },
          "scale": {
            "domain": [0, 7]
          }
        },
        "color": {
          "field": "Measure",
          "scale": {
            "domain": [
              "WPI",
              "Inflation Rate (%)"
            ],
            "range": [
              "#009E73",
              "#D55E00"
            ]
          },
          "legend": {
            "title": "Measure"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Measure",
            "title": "Measure"
          },
          {
            "field": "Value",
            "title": "Rate (%)",
            "format": ".2f"
          }
        ]
      }
    }
  ]
}