{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "grid": true,
      "gridColor": "#2b2b2b",
      "domain": true,
      "domainColor": "#d6cfbf",
      "ticks": true,
      "tickColor": "#d6cfbf",
      "labels": true,
      "labelColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleColor": "#d6cfbf",
      "titleFontSize": 13,
      "titleFontWeight": "bold"
    },
    "legend": {
      "labelColor": "#d6cfbf",
      "titleColor": "#d6cfbf",
      "orient": "top"
    },
    "view": {
      "stroke": "#d6cfbf",
      "strokeWidth": 1
    }
  },
  "width": 760,
  "height": 330,
  "layer": [
    {
      "mark": {
        "type": "rect",
        "color": "#777777",
        "opacity": 0.16
      },
      "encoding": {
        "x": {
          "datum": 2022,
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          }
        },
        "x2": {
          "datum": 2023
        },
        "y": {
          "datum": 0,
          "type": "quantitative",
          "scale": {
            "domain": [0, 7]
          }
        },
        "y2": {
          "datum": 7
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#d6cfbf",
        "dx": 5,
        "dy": 5
      },
      "encoding": {
        "x": {
          "datum": 2022,
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          }
        },
        "y": {
          "datum": 6.85,
          "type": "quantitative",
          "scale": {
            "domain": [0, 7]
          }
        },
        "text": {
          "value": "2022–2023 Australia cost-of-living shock"
        }
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/data/wpi_inflation.csv"
      },
      "transform": [
        {
          "fold": [
            "WPI",
            "Inflation Rate (%)"
          ],
          "as": [
            "Measure",
            "Rate"
          ]
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "size": 55
        }
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "title": "Year",
            "format": "d",
            "values": [
              2015,
              2016,
              2017,
              2018,
              2019,
              2020,
              2021,
              2022,
              2023,
              2024,
              2025
            ],
            "labelAngle": 0,
            "domain": true,
            "ticks": true,
            "labels": true,
            "grid": true
          }
        },
        "y": {
          "field": "Rate",
          "type": "quantitative",
          "scale": {
            "domain": [0, 7]
          },
          "axis": {
            "title": "Rate (%)",
            "values": [
              0,
              1,
              2,
              3,
              4,
              5,
              6,
              7
            ],
            "domain": true,
            "ticks": true,
            "labels": true,
            "grid": true
          }
        },
        "color": {
          "field": "Measure",
          "type": "nominal",
          "scale": {
            "domain": [
              "WPI",
              "Inflation Rate (%)"
            ],
            "range": [
              "#009E73",
              "#D55E00"
            ]
          },
          "legend": {
            "title": "Measure"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Measure",
            "title": "Measure"
          },
          {
            "field": "Rate",
            "title": "Rate (%)",
            "format": ".2f"
          }
        ]
      }
    }
  ]
}