{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#d6cfbf",
      "titleColor": "#d6cfbf",
      "orient": "top"
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "width": "container",
  "height": 320,
  "data": {
    "url": "data/asx200.csv"
  },
  "transform": [
    {
      "fold": [
        "ASX200 Growth (%)",
        "Inflation (%)"
      ],
      "as": [
        "Measure",
        "Value"
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#777777",
        "strokeDash": [
          4,
          4
        ]
      },
      "encoding": {
        "y": {
          "datum": 0,
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "size": 55
        }
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "axis": {
            "format": "d",
            "tickCount": 11,
            "title": "Year"
          }
        },
        "y": {
          "field": "Value",
          "type": "quantitative",
          "axis": {
            "title": "Annual growth (%)"
          }
        },
        "color": {
          "field": "Measure",
          "scale": {
            "domain": [
              "ASX200 Growth (%)",
              "Inflation (%)"
            ],
            "range": [
              "#4caf7d",
              "#e05c3a"
            ]
          },
          "legend": {
            "title": null
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "format": "d"
          },
          {
            "field": "Measure"
          },
          {
            "field": "Value",
            "title": "Growth (%)",
            "format": ".2f"
          }
        ]
      }
    }
  ]
}