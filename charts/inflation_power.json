{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#d6cfbf",
      "titleColor": "#d6cfbf",
      "orient": "top"
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "width": "container",
  "height": 330,
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/data/inflation_100.csv"
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "quantitative",
      "scale": {
        "domain": [2015, 2025]
      },
      "axis": {
        "format": "d",
        "tickCount": 11,
        "title": "Year",
        "labelAngle": 0,
        "labelColor": "#b9b3a5",
        "titleColor": "#d6cfbf",
        "domainColor": "#b9b3a5",
        "tickColor": "#b9b3a5",
        "labelPadding": 8,
        "titlePadding": 12
      }
    }
  },
  "resolve": {
    "scale": {
      "y": "independent"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#0072B2",
        "opacity": 0.18,
        "line": {
          "color": "#0072B2",
          "strokeWidth": 3
        }
      },
      "encoding": {
        "y": {
          "field": "Value of 100$",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": {
            "title": "Real value of $100",
            "orient": "left",
            "titleColor": "#0072B2",
            "labelColor": "#0072B2",
            "domainColor": "#0072B2",
            "tickColor": "#0072B2"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Value of 100$",
            "title": "Real value of $100",
            "format": ".2f"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate (%)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "color": "#E69F00",
        "opacity": 0.85,
        "width": 22
      },
      "encoding": {
        "y": {
          "field": "Inflation Rate (%)",
          "type": "quantitative",
          "scale": {
            "domain": [0, 8]
          },
          "axis": {
            "title": "Inflation rate (%)",
            "orient": "right",
            "titleColor": "#E69F00",
            "labelColor": "#E69F00",
            "domainColor": "#E69F00",
            "tickColor": "#E69F00"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate (%)",
            "format": ".2f"
          },
          {
            "field": "Value of 100$",
            "title": "Real value of $100",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#0072B2",
        "size": 65
      },
      "encoding": {
        "y": {
          "field": "Value of 100$",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": null
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Value of 100$",
            "title": "Real value of $100",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Year == 2020 || datum.Year == 2022"
        },
        {
          "calculate": "datum.Year == 2020 ? 'COVID-19 disruption' : 'Inflation surge'",
          "as": "Major event"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#666666",
        "size": 180,
        "stroke": "#ffffff",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "Value of 100$",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": null
        },
        "shape": {
          "field": "Major event",
          "type": "nominal",
          "scale": {
            "domain": [
              "COVID-19 disruption",
              "Inflation surge"
            ],
            "range": [
              "circle",
              "square"
            ]
          },
          "legend": {
            "title": "Major event"
          }
        },
        "tooltip": [
          {
            "field": "Major event",
            "title": "Major event"
          },
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Value of 100$",
            "title": "Real value of $100",
            "format": ".2f"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate (%)",
            "format": ".2f"
          }
        ]
      }
    }
  ]
}