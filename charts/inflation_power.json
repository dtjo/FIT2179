{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "padding": {
    "left": 4,
    "right": 6,
    "top": 4,
    "bottom": 4
  },
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#d6cfbf",
      "titleColor": "#d6cfbf",
      "orient": "top"
    },
    "view": {
      "stroke": "transparent",
      "fill": "#0f1f2e",
      "cornerRadius": 8
    }
  },
  "width": "container",
  "height": 460,
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/data/inflation_100.csv"
  },
  "transform": [
    {
      "calculate": "datum['Value of 100$']",
      "as": "Real value"
    }
  ],
  "resolve": {
    "scale": {
      "y": "independent"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#0072B2",
        "opacity": 0.18,
        "line": {
          "color": "#0072B2",
          "strokeWidth": 3
        }
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "title": "Year",
            "format": "d",
            "values": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],
            "labelAngle": 0,
            "labelColor": "#b9b3a5",
            "titleColor": "#d6cfbf",
            "domainColor": "#b9b3a5",
            "tickColor": "#b9b3a5",
            "grid": true
          }
        },
        "y": {
          "field": "Real value",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": {
            "title": "Real value",
            "orient": "left",
            "titleColor": "#0072B2",
            "labelColor": "#0072B2",
            "domainColor": "#0072B2",
            "tickColor": "#0072B2"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Real value",
            "title": "Real value",
            "format": ".2f"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "color": "#E69F00",
        "opacity": 0.85,
        "width": 18
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "title": "Year",
            "format": "d",
            "values": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],
            "labelAngle": 0,
            "labelColor": "#b9b3a5",
            "titleColor": "#d6cfbf",
            "domainColor": "#b9b3a5",
            "tickColor": "#b9b3a5",
            "grid": true
          }
        },
        "y": {
          "field": "Inflation Rate (%)",
          "type": "quantitative",
          "scale": {
            "domain": [0, 7.5]
          },
          "axis": {
            "title": "Inflation rate",
            "orient": "right",
            "titleColor": "#E69F00",
            "labelColor": "#E69F00",
            "domainColor": "#E69F00",
            "tickColor": "#E69F00"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate",
            "format": ".2f"
          },
          {
            "field": "Real value",
            "title": "Real value",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#0072B2",
        "size": 55
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "title": "Year",
            "format": "d",
            "values": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Real value",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": null
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Real value",
            "title": "Real value",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2020,
            "Real value": 92.37,
            "Event": "2020 COVID-19 shock"
          },
          {
            "Year": 2022,
            "Real value": 83.81,
            "Event": "2022 inflation surge"
          }
        ]
      },
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#666666",
        "size": 150,
        "stroke": "#d6cfbf",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "title": "Year",
            "format": "d",
            "values": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Real value",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": null
        },
        "shape": {
          "field": "Event",
          "type": "nominal",
          "scale": {
            "domain": [
              "2020 COVID-19 shock",
              "2022 inflation surge"
            ],
            "range": [
              "circle",
              "square"
            ]
          },
          "legend": {
            "title": "Major event"
          }
        },
        "tooltip": [
          {
            "field": "Event",
            "title": "Major event"
          },
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Real value",
            "title": "Real value",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2020.08,
            "Real value": 99,
            "Label": "COVID-19 period"
          },
          {
            "Year": 2022.08,
            "Real value": 90,
            "Label": "Inflation surge"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#d6cfbf",
        "dx": 6
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2015, 2025]
          },
          "axis": {
            "title": "Year",
            "format": "d",
            "values": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Real value",
          "type": "quantitative",
          "scale": {
            "domain": [0, 105]
          },
          "axis": null
        },
        "text": {
          "field": "Label"
        }
      }
    }
  ]
}