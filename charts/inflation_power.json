{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "disable": true
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "width": "container",
  "height": 330,
  "data": {
    "url": "data/inflation_100.csv"
  },
  "resolve": {
    "scale": {
      "y": "independent"
    }
  },
  "layer": [
    {
      "data": {
        "values": [
          {
            "start": 2020,
            "end": 2021.5,
            "event": "COVID-19 disruption"
          }
        ]
      },
      "mark": {
        "type": "rect",
        "color": "#999999",
        "opacity": 0.18
      },
      "encoding": {
        "x": {
          "field": "start",
          "type": "quantitative"
        },
        "x2": {
          "field": "end"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2020.1,
            "value": 103,
            "event": "COVID-19 disruption"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#d6cfbf"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "scale": {
            "domain": [65, 105]
          },
          "axis": null
        },
        "text": {
          "field": "event"
        }
      }
    },
    {
      "mark": {
        "type": "bar",
        "color": "#E69F00",
        "opacity": 0.75,
        "width": 22
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "axis": {
            "format": "d",
            "tickCount": 11,
            "title": "Year"
          }
        },
        "y": {
          "field": "Inflation Rate (%)",
          "type": "quantitative",
          "scale": {
            "domain": [0, 8]
          },
          "axis": {
            "title": "Inflation rate (%)",
            "titleColor": "#E69F00"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate (%)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#0072B2",
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "axis": {
            "format": "d",
            "tickCount": 11,
            "title": "Year"
          }
        },
        "y": {
          "field": "Value of 100$",
          "type": "quantitative",
          "scale": {
            "domain": [65, 105]
          },
          "axis": {
            "title": "Real value of $100",
            "titleColor": "#0072B2"
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Value of 100$",
            "title": "Real value of $100",
            "format": ".2f"
          },
          {
            "field": "Inflation Rate (%)",
            "title": "Inflation rate (%)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#0072B2",
        "size": 70
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative"
        },
        "y": {
          "field": "Value of 100$",
          "type": "quantitative",
          "scale": {
            "domain": [65, 105]
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Value of 100$",
            "title": "Real value of $100",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2025,
            "Value of 100$": 73.93,
            "label": "Real value of $100"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#0072B2"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative"
        },
        "y": {
          "field": "Value of 100$",
          "type": "quantitative",
          "scale": {
            "domain": [65, 105]
          }
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2025,
            "Inflation Rate (%)": 3.8,
            "label": "Inflation rate"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#E69F00"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative"
        },
        "y": {
          "field": "Inflation Rate (%)",
          "type": "quantitative",
          "scale": {
            "domain": [0, 8]
          }
        },
        "text": {
          "field": "label"
        }
      }
    }
  ]
}