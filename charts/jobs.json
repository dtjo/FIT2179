{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": { "labelColor": "#d6cfbf", "titleColor": "#d6cfbf" },
    "view": { "stroke": "transparent" }
  },
  "width": "container",
  "height": 290,
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/data/jobs.csv"
  },
  "transform": [
    {
      "calculate": "parseInt('20' + datum.Date.split('-')[1]) + (datum.Date.split('-')[0] === 'Mar' ? 0 : datum.Date.split('-')[0] === 'Jun' ? 0.25 : datum.Date.split('-')[0] === 'Sep' ? 0.5 : 0.75)",
      "as": "year_frac"
    }
  ],
  "mark": {
    "type": "area",
    "color": "#e05c3a",
    "opacity": 0.14,
    "line": { "color": "#e05c3a", "strokeWidth": 2.5 },
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "year_frac",
      "type": "quantitative",
      "scale": { "domain": [2015, 2026] },
      "axis": {
        "title": "Year",
        "format": "d",
        "values": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026],
        "grid": false,
        "labelAngle": 0
      }
    },
    "y": {
      "field": "Multiple Job Holding Rate (%)",
      "type": "quantitative",
      "scale": { "zero": false, "domain": [5, 7] },
      "axis": { "title": "Multiple job holding rate (%)", "tickCount": 5 }
    },
    "tooltip": [
      { "field": "Date", "title": "Quarter" },
      { "field": "Multiple Job Holding Rate (%)", "title": "Rate (%)", "format": ".1f" }
    ]
  }
}