{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": { "labelColor": "#d6cfbf", "titleColor": "#d6cfbf" },
    "view": { "stroke": "transparent" }
  },
  "width": "container",
  "height": 290,
  "data": {
    "url": "https://raw.githubusercontent.com/dtjo/FIT2179/main/data/jobs.csv",
    "format": { "type": "csv", "parse": { "Date": "date:'%b-%y'" } }
  },
  "encoding": {
    "x": {
      "field": "Date",
      "type": "temporal",
      "axis": {
        "title": "Year",
        "format": "%Y",
        "tickCount": "year",
        "labelAngle": 0,
        "grid": false
      }
    },
    "y": {
      "field": "Multiple Job Holding Rate (%)",
      "type": "quantitative",
      "scale": { "zero": false, "domain": [5, 7] },
      "axis": { "title": "Multiple job holding rate (%)", "tickCount": 5 }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#e05c3a",
        "opacity": 0.14,
        "clip": true
      },
      "encoding": {
        "y2": { "datum": 5 }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#e05c3a",
        "strokeWidth": 2.5,
        "clip": true
      },
      "encoding": {
        "tooltip": [
          { "field": "Date", "type": "temporal", "title": "Quarter", "format": "%b %Y" },
          { "field": "Multiple Job Holding Rate (%)", "title": "Rate (%)", "format": ".1f" }
        ]
      }
    }
  ]
}