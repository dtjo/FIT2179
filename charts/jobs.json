{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "axis": {
      "gridColor": "#2b2b2b",
      "domainColor": "#393939",
      "tickColor": "#393939",
      "labelColor": "#b9b3a5",
      "titleColor": "#d6cfbf",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#d6cfbf",
      "titleColor": "#d6cfbf",
      "orient": "top"
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "width": "container",
  "height": 290,
  "data": {
    "url": "data/jobs.csv"
  },
  "mark": {
    "type": "area",
    "color": "#e05c3a",
    "opacity": 0.14,
    "line": {
      "color": "#e05c3a",
      "strokeWidth": 3
    }
  },
  "encoding": {
    "x": {
      "field": "Date",
      "type": "ordinal",
      "axis": {
        "labelAngle": -60,
        "labelOverlap": true,
        "title": "Quarter"
      }
    },
    "y": {
      "field": "Multiple Job Holding Rate (%)",
      "type": "quantitative",
      "scale": {
        "zero": false
      },
      "axis": {
        "title": "Multiple job holding rate (%)"
      }
    },
    "tooltip": [
      {
        "field": "Date"
      },
      {
        "field": "Multiple Job Holding Rate (%)",
        "format": ".1f"
      }
    ]
  }
}